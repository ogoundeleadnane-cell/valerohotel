<title>Valero Hôtel — Cotonou, Bénin</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,200;0,300;0,400;0,600;1,200;1,300;1,400&family=Montserrat:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --or:#C9A84C;--or2:#E8C96A;--or3:#F5DFA0;
  --bx:#6B1A2A;--bx2:#4a0f1c;
  --noir:#0A0A0A;--blanc:#FAFAF8;--gris:#F5F3EE;--texte:#1A1010;
}
html{scroll-behavior:smooth;}
body{font-family:'Montserrat',sans-serif;background:var(--blanc);color:var(--texte);overflow-x:hidden;}

/* ── NAVBAR ── */
nav{position:fixed;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:0 5%;height:70px;background:#200007;backdrop-filter:blur(12px);border-bottom:1px solid rgba(201,168,76,0.2);}
.nav-logo img{height:46px;object-fit:contain;}
.nav-links{display:flex;gap:28px;list-style:none;}
.nav-links a{color:rgba(255,255,255,0.7);text-decoration:none;font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;transition:color .2s;padding-bottom:4px;border-bottom:1px solid transparent;}
.nav-links a:hover,.nav-links a.active{color:var(--or);border-bottom-color:var(--or);}
.nav-cta{background:var(--or);color:var(--noir);font-weight:700;font-size:11px;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;padding:10px 22px;border-radius:2px;transition:all .2s;}
.nav-cta:hover{background:var(--or2);}
.nav-burger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px;}
.nav-burger span{display:block;width:22px;height:2px;background:white;}

/* ── HERO ── */

#hero{
  min-height:100vh;position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  background:#4A0010;
}
.hero-bg-grid{
  position:absolute;inset:0;z-index:0;
  background-image:
    repeating-linear-gradient(0deg,rgba(201,168,76,0.04) 0,rgba(201,168,76,0.04) 1px,transparent 1px,transparent 64px),
    repeating-linear-gradient(90deg,rgba(201,168,76,0.04) 0,rgba(201,168,76,0.04) 1px,transparent 1px,transparent 64px);
}
.hero-slideshow{position:absolute;inset:0;z-index:0;}
.hero-slide{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity 1.6s ease;}
.hero-slide.active{opacity:1;}
.hero-slide::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(20,4,8,0.32) 0%,rgba(20,4,8,0.5) 55%,rgba(10,2,4,0.78) 100%);}
.hero-dots{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:3;display:flex;gap:10px;}
.hero-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.35);cursor:pointer;transition:background .3s,transform .3s;border:none;padding:0;}
.hero-dot.active{background:var(--or);transform:scale(1.25);}
.hero-glow{position:absolute;inset:0;z-index:1;background:radial-gradient(ellipse at 30% 60%,rgba(107,26,42,0.25) 0%,transparent 60%),radial-gradient(ellipse at 70% 30%,rgba(201,168,76,0.1) 0%,transparent 55%);}
.hero-content{position:relative;z-index:2;text-align:center;padding:0 5%;max-width:860px;}
.hero-logo{width:110px;margin:0 auto 28px;display:block;filter:drop-shadow(0 0 20px rgba(201,168,76,0.3));}
.hero-sep{display:flex;align-items:center;gap:16px;justify-content:center;margin-bottom:20px;}
.hero-sep-line{width:40px;height:1px;background:rgba(201,168,76,0.5);}
.hero-sep-dot{width:5px;height:5px;background:var(--or);border-radius:50%;}
.hero-tagline{font-size:11px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--or);}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(52px,9vw,110px);font-weight:300;color:white;line-height:.95;letter-spacing:.02em;margin-bottom:12px;}
.hero-title em{color:var(--or);font-style:italic;display:block;}
.hero-stars{color:var(--or);font-size:18px;letter-spacing:6px;margin:20px 0 8px;}
.hero-sub{font-size:13px;font-weight:300;letter-spacing:.18em;color:rgba(255,255,255,0.45);margin-bottom:44px;text-transform:uppercase;}
.hero-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.hero-scroll{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:2;text-align:center;}
.scroll-txt{font-size:9px;letter-spacing:.22em;color:rgba(255,255,255,0.3);text-transform:uppercase;margin-bottom:8px;}
.scroll-line{width:1px;height:36px;background:linear-gradient(to bottom,rgba(201,168,76,0.5),transparent);margin:0 auto;animation:sc 2s infinite;}
@keyframes sc{0%{opacity:1;height:0}100%{opacity:0;height:36px}}


/* ── RIBBON ── */
#ribbon{background:var(--bx);padding:0 5%;overflow:hidden;}
.ribbon-track{
  display:flex;gap:0;animation:ribbonScroll 20s linear infinite;
  width:max-content;
}
.ribbon-item{
  padding:18px 48px;border-right:1px solid rgba(255,255,255,0.1);
  font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;
  color:rgba(255,255,255,0.7);white-space:nowrap;display:flex;align-items:center;gap:12px;
}
.ribbon-item span{color:var(--or);font-size:14px;}
@keyframes ribbonScroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ── STATS ── */
#stats{background:#200007;padding:56px 5%;}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);}
.stat-item{
  padding:36px 20px;text-align:center;
  border-right:1px solid rgba(201,168,76,0.12);
  position:relative;
}
.stat-item:last-child{border-right:none;}
.stat-item::before{
  content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:1px;height:4px;background:var(--or);
}
.stat-num{
  font-family:'Cormorant Garamond',serif;
  font-size:58px;font-weight:200;color:var(--or2);line-height:1;
}
.stat-lbl{font-size:10px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-top:10px;}

/* ── CHAMBRES ── */
#chambres{padding:120px 5% 0;background:var(--gris);}
.ch-header{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:56px;}
.ch-header-right{text-align:right;}
.ch-header-right p{font-size:14px;font-weight:300;line-height:1.9;color:#5A4A4A;}
.ch-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:3px;}
.ch-card{position:relative;overflow:hidden;cursor:pointer;}
.ch-card:first-child{grid-row:span 2;}
.ch-card img{width:100%;height:100%;min-height:260px;object-fit:cover;display:block;transition:transform .8s cubic-bezier(.25,.46,.45,.94);}
.ch-card:first-child img{min-height:530px;}
.ch-card:hover img{transform:scale(1.06);}
.ch-ov{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(10,10,10,0.92) 0%,rgba(10,10,10,0.1) 55%,transparent 100%);
  display:flex;flex-direction:column;justify-content:flex-end;padding:28px;
  opacity:0;transition:opacity .4s;
}
.ch-card:hover .ch-ov{opacity:1;}
.ch-ov-always{
  position:absolute;bottom:0;left:0;right:0;
  background:linear-gradient(to top,rgba(10,10,10,0.85) 0%,transparent 100%);
  padding:28px;
}
.ch-cat{font-size:9px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--or);margin-bottom:6px;}
.ch-name{font-family:'Cormorant Garamond',serif;font-size:26px;color:white;margin-bottom:4px;line-height:1.1;}
.ch-card:first-child .ch-name{font-size:34px;}
.ch-price{font-size:14px;font-weight:600;color:var(--or2);margin-bottom:16px;}
.ch-btn{
  display:inline-block;background:var(--or);color:var(--noir);
  font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  text-decoration:none;padding:10px 22px;border-radius:1px;
  transition:all .2s;
}
.ch-btn:hover{background:var(--or2);}
.ch-footer{padding:32px 0 120px;text-align:center;}

/* ── ABOUT STRIP ── */
#about-strip{background:var(--blanc);padding:120px 5%;}
.about-strip-grid{display:grid;grid-template-columns:1fr 1fr;gap:100px;align-items:center;}
.about-img-comp{position:relative;height:560px;}
.ai-main{position:absolute;right:0;top:0;width:78%;height:460px;object-fit:cover;}
.ai-accent{position:absolute;left:0;bottom:0;width:50%;height:300px;object-fit:cover;border:6px solid var(--blanc);box-shadow:0 20px 60px rgba(0,0,0,0.1);}
.ai-badge{
  position:absolute;right:0;bottom:-20px;
  background:var(--bx);color:white;padding:22px 28px;text-align:center;
  box-shadow:0 8px 32px rgba(107,26,42,0.3);
}
.ai-badge-num{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:200;line-height:1;color:var(--or2);}
.ai-badge-txt{font-size:10px;letter-spacing:.12em;opacity:.7;margin-top:4px;}
.about-txt .section-tag{color:var(--bx);}
.services-list{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px;}
.sv{display:flex;align-items:center;gap:10px;font-size:13px;color:#4A3A3A;}
.sv::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--or);flex-shrink:0;}

/* ── ESPACES ── */
#espaces{background:white;padding:120px 5%;}
.esp-header{text-align:center;margin-bottom:64px;}
.esp-header .section-title{color:white;}
.esp-header .section-title em{color:var(--or);}
.esp-mosaic{display:grid;grid-template-columns:1fr 1fr 1fr;grid-template-rows:300px 280px;gap:3px;}
.esp-tile{position:relative;overflow:hidden;cursor:pointer;}
.esp-tile:first-child{grid-row:span 2;grid-column:span 1;}
.esp-tile img{width:100%;height:100%;object-fit:cover;transition:transform .8s;}
.esp-tile:hover img{transform:scale(1.06);}
.esp-tile-ov{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(10,10,10,0.9) 0%,rgba(10,10,10,0.1) 60%,transparent 100%);
  padding:24px;display:flex;flex-direction:column;justify-content:flex-end;
}
.et-name{font-family:'Cormorant Garamond',serif;font-size:24px;color:white;margin-bottom:4px;}
.esp-tile:first-child .et-name{font-size:32px;}
.et-price{font-size:12px;color:var(--or);font-weight:600;margin-bottom:12px;}
.et-link{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,0.6);text-decoration:none;transition:color .2s;}
.et-link:hover{color:var(--or);}



/* ── CTA FINAL ── */
#cta{
  background:linear-gradient(150deg,var(--bx2) 0%,var(--bx) 50%,#8B1A30 100%);
  padding:120px 5%;text-align:center;position:relative;overflow:hidden;
}
#cta::before{
  content:'V';
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  font-family:'Cormorant Garamond',serif;font-size:500px;font-weight:200;
  color:rgba(255,255,255,0.03);line-height:1;pointer-events:none;
}
.cta-tag{font-size:10px;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:var(--or);margin-bottom:16px;display:block;}
.cta-title{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,6vw,72px);color:white;font-weight:200;line-height:1.1;margin-bottom:16px;}
.cta-title em{color:var(--or);font-style:italic;}
.cta-sub{font-size:14px;color:rgba(255,255,255,0.6);max-width:480px;margin:0 auto 48px;line-height:1.8;}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}
.btn-or{background:var(--or);color:var(--noir);font-weight:700;font-size:11px;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;padding:16px 40px;border-radius:1px;transition:all .25s;display:inline-block;}
.btn-or:hover{background:var(--or2);transform:translateY(-2px);box-shadow:0 12px 36px rgba(201,168,76,0.3);}
.btn-ghost{border:1px solid rgba(255,255,255,0.35);color:white;background:transparent;font-weight:600;font-size:11px;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;padding:16px 40px;border-radius:1px;transition:all .25s;display:inline-block;}
.btn-ghost:hover{border-color:var(--or);color:var(--or);}

/* ── FOOTER ── */
footer{background:#200007;padding:56px 5% 28px;}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px;margin-bottom:40px;}
.footer-logo{width:72px;margin-bottom:14px;}
.footer-desc{font-size:12px;color:rgba(255,255,255,0.35);line-height:1.8;max-width:260px;margin-bottom:16px;}
.footer-stars{color:var(--or);font-size:15px;letter-spacing:4px;}
.footer-col-title{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:16px;}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:10px;}
.footer-links a{text-decoration:none;font-size:12px;color:rgba(255,255,255,0.45);transition:color .2s;}
.footer-links a:hover{color:var(--or);}
.footer-bottom{border-top:1px solid rgba(255,255,255,0.06);padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
.footer-copy{font-size:11px;color:rgba(255,255,255,0.2);}
.footer-or-line{width:36px;height:1px;background:var(--or);opacity:.4;}

@media(max-width:860px){
  .nav-links{display:none;}.nav-burger{display:flex;}
  .footer-grid{grid-template-columns:1fr;}
}
/* ── UTILS ── */
.section-tag{font-size:10px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--or);margin-bottom:12px;display:block;}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(32px,4vw,54px);font-weight:300;color:var(--texte);line-height:1.1;margin-bottom:14px;}
.section-title em{color:var(--bx);font-style:italic;}
.gold-line{width:44px;height:1.5px;background:var(--or);margin:18px 0;}
.text-center .gold-line{margin:18px auto;}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .8s ease,transform .8s ease;}
.reveal.visible{opacity:1;transform:none;}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  .nav-links{display:none;flex-direction:column;position:absolute;top:72px;left:0;right:0;background:rgba(10,10,10,0.98);padding:20px 5%;gap:0;}
  .nav-links.open{display:flex;}
  .nav-links li{border-bottom:1px solid rgba(255,255,255,0.06);}
  .nav-links a{padding:16px 0;display:block;}
  .nav-burger{display:flex;}
  .ch-header,.about-strip-grid{grid-template-columns:1fr;gap:40px;}
  .ch-grid{grid-template-columns:1fr;}
  .ch-card:first-child{grid-row:span 1;}
  .ch-card:first-child img{min-height:300px;}
  .esp-mosaic{grid-template-columns:1fr;grid-template-rows:auto;}
  .esp-tile:first-child{grid-row:span 1;}
  .temo-grid{grid-template-columns:1fr;}
  .footer-top{grid-template-columns:1fr 1fr;}
  .stats-row{grid-template-columns:1fr 1fr;}
}
</style>
</head>
